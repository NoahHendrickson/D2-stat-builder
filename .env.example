# ──────────────────────────────────────────────────────────────────────────
# Bungie application credentials
# Create an app at https://www.bungie.net/en/Application
#   • OAuth Client Type: Confidential
#   • Redirect URL:      https://localhost:4321/api/auth/callback
#   • Scope:             "Read your Destiny ... inventory and Vault"
# Then copy this file to `.env.local` and fill in the three values below.
# ──────────────────────────────────────────────────────────────────────────

# Server-only — the confidential OAuth credentials. NEVER prefix with NEXT_PUBLIC.
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=

# Sent as the X-API-Key header on every Bungie API call. The browser uses it too
# (for direct GetProfile / manifest calls later), so it is intentionally public.
NEXT_PUBLIC_BUNGIE_API_KEY=

# Base URL of this app — used to build the OAuth redirect URI (must match the
# value registered in the Bungie portal exactly).
NEXT_PUBLIC_APP_URL=https://localhost:4321
